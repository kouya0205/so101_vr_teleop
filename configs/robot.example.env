# Copy to configs/robot.env and fill in your serial ports.
# Source before running:  set -a && source configs/robot.env && set +a

export SO101_LEFT_PORT=/dev/ttyACM0
export SO101_RIGHT_PORT=/dev/ttyACM1
export SO101_ROBOT_ID=bi_so101
export HF_USER=kouya0205
# Optional task slug used in auto repo_id: {HF_USER}/so101_bi_{TASK}_vNNN
# Prefer configs/record.env for collection hyperparameters.
export SO101_TASK=demo
