# Recording hyperparameters (optional). Copy to configs/record.env:
#   cp configs/record.example.env configs/record.env
#
# Sourced automatically by scripts/env.sh when present.

# Short slug used in repo_id: {HF_USER}/so101_bi_{SO101_TASK}_vNNN
export SO101_TASK=demo

# Language label stored in every frame (LeRobot task field)
export SO101_SINGLE_TASK="Pick the object with both arms and place it in the bin"

export SO101_NUM_EPISODES=10
export SO101_EPISODE_TIME_S=40
export SO101_RESET_TIME_S=15
export SO101_DATASET_FPS=30

# Keep false until a session looks good; then flip to true or push later.
export SO101_PUSH_TO_HUB=false

# If CloudXR is already running in another terminal (recommended):
export LEROBOT_CLOUDXR_SKIP_AUTOLAUNCH=1
